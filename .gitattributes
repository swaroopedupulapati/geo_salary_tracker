# Normalize text file line endings across platforms.
# Use native line endings in working tree, store LF in repository.
* text=auto

# Explicitly enforce Unix-style line endings for script files.
*.sh text eol=lf
*.yml text eol=lf
*.yaml text eol=lf

# Mark binary files to prevent CRLF normalization.
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.pdf binary
*.jar binary
*.keystore binary
*.pbxproj binary
